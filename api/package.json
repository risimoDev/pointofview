{
  "name": "viziai-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "worker:clips": "tsx src/workers/clips.worker.ts",
    "worker:alerts": "tsx src/workers/alerts.worker.ts",
    "worker:ai": "tsx src/workers/ai.worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "migrate": "tsx db/migrate.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "minio": "^8.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "ioredis": "^5.4.2"
  }
}
