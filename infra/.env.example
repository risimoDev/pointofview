# ── Deployment ──────────────────────────────────────────────
DEPLOYMENT_MODE=cloud
TZ=Europe/Moscow
PUID=1000
PGID=1000

# ── PostgreSQL + TimescaleDB ────────────────────────────────
POSTGRES_USER=viziai
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=viziai
POSTGRES_PORT=5432
# DATABASE_URL для api (Drizzle) и analyzer
DATABASE_URL=postgresql://viziai:change_me_strong@localhost:5432/viziai

# ── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO (S3) ──────────────────────────────────────────────
MINIO_ROOT_USER=viziai
MINIO_ROOT_PASSWORD=change_me_strong
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=viziai
MINIO_SECRET_KEY=change_me_strong
MINIO_BUCKET_CLIPS=clips
MINIO_BUCKET_SNAPSHOTS=snapshots

# ── go2rtc ──────────────────────────────────────────────────
GO2RTC_API_PORT=1984
GO2RTC_WEBRTC_PORT=8555
GO2RTC_URL=http://localhost:1984

# ── Clips worker (ffmpeg) ───────────────────────────────────
CLIP_TMP_DIR=/tmp/clips
CLIP_PRE_ROLL_SEC=10
CLIP_POST_ROLL_SEC=5
CLIP_WATERMARK=true
CLIP_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
FFMPEG_BIN=ffmpeg

# ── Archive recorder (analyzer/ingest/recorder.py) ──────────
ARCHIVE_ROOT=/mnt/data/archive
SEGMENT_SECONDS=300
INTERNAL_API_URL=http://localhost:3000

# ── Service-to-service auth (recorder → /internal) ──────────
INTERNAL_TOKEN=change_me_internal_token

# ── Alerts (Telegram) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WireGuard ───────────────────────────────────────────────
WG_SERVERPORT=51820

# ── API / Auth ──────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=change_me_jwt_secret

# ── Analyzer (один воркер = один тенант) ────────────────────
TENANT_ID=00000000-0000-0000-0000-000000000000
ANALYZER_DEVICE=cuda

# ── Web (Next.js) ───────────────────────────────────────────
# server-side (rewrites, login route)
API_URL=http://localhost:3000
# client-side: прямой WS к API (rewrite не проксирует upgrade)
NEXT_PUBLIC_WS_URL=ws://localhost:3000
