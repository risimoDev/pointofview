# Production env for the home GPU server.
# Copy to .env.prod and fill in. Generate secrets: openssl rand -hex 32

# ── Deployment ──────────────────────────────────────────────
DEPLOYMENT_MODE=cloud
TZ=Europe/Moscow

# Public entrypoints (VPS)
DOMAIN=viziai.example.ru
VPS_PUBLIC_IP=203.0.113.10
# baked into the web build: browser connects to wss://<domain>
PUBLIC_WS_URL=wss://viziai.example.ru
# presigned clip/snapshot URLs opened by browsers (s3 subdomain on the VPS)
MINIO_PUBLIC_ENDPOINT=https://s3.viziai.example.ru

# Where MinIO data and the video archive live (big disk!)
DATA_ROOT=/mnt/data

# ── PostgreSQL + TimescaleDB ────────────────────────────────
POSTGRES_USER=viziai
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=viziai

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=viziai
MINIO_ROOT_PASSWORD=change_me_strong
MINIO_BUCKET_CLIPS=clips
MINIO_BUCKET_SNAPSHOTS=snapshots

# ── Auth / service-to-service ───────────────────────────────
JWT_SECRET=change_me_jwt_secret_64_hex
INTERNAL_TOKEN=change_me_internal_token

# ── Alerts ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Clips ───────────────────────────────────────────────────
CLIP_PRE_ROLL_SEC=10
CLIP_POST_ROLL_SEC=5
CLIP_WATERMARK=true
SEGMENT_SECONDS=300

# ── Analyzer ────────────────────────────────────────────────
TENANT_ID=00000000-0000-0000-0000-000000000000
# RTX 3070 8GB: yolov8s.pt is a good default; yolov8n.pt if >8 cameras
YOLO_MODEL=yolov8s.pt
DEFAULT_FRAME_SKIP=2
