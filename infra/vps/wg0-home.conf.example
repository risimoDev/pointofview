# Home GPU server: /etc/wireguard/wg0.conf — client of the VPS hub.
# Enable: systemctl enable --now wg-quick@wg0

[Interface]
Address = 10.9.0.2/24
PrivateKey = ePaDV2tU2XsLk3FonMBsQkmvcLWfujEWGYKeOGp7RUg=

[Peer]
PublicKey = DUK2xYhWPXmW2YZ2e5hwLoGRoHdE6FT9wFaO/xJiXXo=
Endpoint = 170.168.1.138:51820
# whole WG subnet routes through the VPS (cameras included)
