# Home GPU server: /etc/wireguard/wg0.conf — client of the VPS hub.
# Enable: systemctl enable --now wg-quick@wg0

[Interface]
Address = 10.9.0.2/24
PrivateKey = <HOME_SERVER_PRIVATE_KEY>

[Peer]
PublicKey = <VPS_PUBLIC_KEY>
Endpoint = <VPS_PUBLIC_IP>:51820
# whole WG subnet routes through the VPS (cameras included)
AllowedIPs = 10.9.0.0/24
# home server is behind NAT: keep the tunnel open
PersistentKeepalive = 25
