# Home GPU server: /etc/amnezia/amneziawg/awg0.conf — client of the VPS hub.
# Enable: systemctl enable --now awg-quick@awg0
#
# Jc/Jmin/Jmax/S1-S4/H1-H4 must be IDENTICAL to the VPS hub config
# (wg0-vps.conf.example) — copy the real values from the VPS, do not regenerate.
# Real values live only in the local awg0.conf (gitignored), never in git.

[Interface]
Address = 10.9.0.2/24
PrivateKey = <HOME_PRIVATE_KEY>

Jc = <JC>
Jmin = <JMIN>
Jmax = <JMAX>
S1 = <S1>
S2 = <S2>
S3 = <S3>
S4 = <S4>
H1 = <H1>
H2 = <H2>
H3 = <H3>
H4 = <H4>

[Peer]
PublicKey = <VPS_PUBLIC_KEY>
Endpoint = <VPS_PUBLIC_IP>:51820
# whole WG subnet routes through the VPS (cameras included)
AllowedIPs = 10.9.0.0/24
# home server is behind NAT: keep the tunnel open
PersistentKeepalive = 25
