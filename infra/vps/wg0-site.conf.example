# Camera site (ПВЗ): AmneziaWG client on the site router (Keenetic/MikroTik/
# OpenWrt with amneziawg package/app, or a mini-PC) or a mini-PC. The camera
# itself stays in the site LAN; the router forwards RTSP :554 from its WG
# address to the camera.
#
# Jc/Jmin/Jmax/S1-S4/H1-H4 must be IDENTICAL to the VPS hub config —
# copy the real values from the VPS awg0.conf, do not regenerate.
# Real values live only in local configs (gitignored), never in git.

[Interface]
Address = 10.9.0.11/32
PrivateKey = <SITE_PRIVATE_KEY>

Jc = <JC>
Jmin = <JMIN>
Jmax = <JMAX>
S1 = <S1>
S2 = <S2>
S3 = <S3>
S4 = <S4>
H1 = <H1>
H2 = <H2>
H3 = <H3>
H4 = <H4>

[Peer]
PublicKey = <VPS_PUBLIC_KEY>
Endpoint = <VPS_PUBLIC_IP>:51820
# only tunnel traffic to the platform subnet, not the site's internet
AllowedIPs = 10.9.0.0/24
PersistentKeepalive = 25

# MikroTik example (camera LAN 192.168.88.64):
#   /ip firewall nat add chain=dstnat dst-address=10.9.0.11 protocol=tcp \
#       dst-port=554 action=dst-nat to-addresses=192.168.88.64 to-ports=554
# Then go2rtc pulls rtsp://user:pass@10.9.0.11:554/...
#
# ВАЖНО: встроенный WireGuard в RouterOS (MikroTik) НЕ поддерживает параметры
# Jc/Jmin/../H4 — если у точки провайдер тоже режет ванильный WireGuard,
# нужен OpenWrt с пакетом amneziawg или мини-ПК рядом с роутером.
