# VPS: /etc/amnezia/amneziawg/awg0.conf — AmneziaWG hub (WireGuard-совместимый
# протокол с обфускацией трафика — обычный WireGuard здесь ловил DPI-блокировку
# провайдера домашнего сервера: хендшейк стабильно рвался каждые ~2 минуты).
# Peers: home GPU server (10.9.0.2) + camera sites (10.9.0.11+).
# Keys: awg genkey | tee privatekey | awg pubkey > publickey
#
# Jc/Jmin/Jmax/S1-S4/H1-H4 ДОЛЖНЫ БЫТЬ ОДИНАКОВЫМИ на всех пирах этой сети
# (VPS + домашний сервер + все точки). Генерируются случайно ОДИН РАЗ при
# создании сети (диапазоны: Jc 3–10, Jmin 50, Jmax 1000, S1/S2 15–150,
# H1–H4 — четыре РАЗНЫХ числа 5–2147483647) — при добавлении нового пира
# просто скопируй значения с VPS, не генерируй заново.
#
# РЕАЛЬНЫЕ значения (ключи, IP, обфускационные параметры) — только в локальном
# awg0.conf, он в .gitignore и в git не попадает.

[Interface]
Address = 10.9.0.1/24
ListenPort = 51820
PrivateKey = <VPS_PRIVATE_KEY>

Jc = <JC>
Jmin = <JMIN>
Jmax = <JMAX>
S1 = <S1>
S2 = <S2>
S3 = <S3>
S4 = <S4>
H1 = <H1>
H2 = <H2>
H3 = <H3>
H4 = <H4>

# route between peers + expose go2rtc WebRTC (:8555) at the public IP
PostUp = sysctl -w net.ipv4.ip_forward=1
PostUp = iptables -A FORWARD -i awg0 -j ACCEPT
PostUp = iptables -A FORWARD -o awg0 -j ACCEPT
PostUp = iptables -t nat -A PREROUTING -p tcp --dport 8555 -j DNAT --to-destination 10.9.0.2:8555
PostUp = iptables -t nat -A PREROUTING -p udp --dport 8555 -j DNAT --to-destination 10.9.0.2:8555
PostUp = iptables -t nat -A POSTROUTING -o awg0 -j MASQUERADE
PostDown = iptables -D FORWARD -i awg0 -j ACCEPT
PostDown = iptables -D FORWARD -o awg0 -j ACCEPT
PostDown = iptables -t nat -D PREROUTING -p tcp --dport 8555 -j DNAT --to-destination 10.9.0.2:8555
PostDown = iptables -t nat -D PREROUTING -p udp --dport 8555 -j DNAT --to-destination 10.9.0.2:8555
PostDown = iptables -t nat -D POSTROUTING -o awg0 -j MASQUERADE

# ── home GPU server ─────────────────────────────────────────
[Peer]
PublicKey = <HOME_PUBLIC_KEY>
AllowedIPs = 10.9.0.2/32

# ── camera site (ПВЗ №1): router or camera with WG client ──
# [Peer]
# PublicKey = <SITE1_PUBLIC_KEY>
# AllowedIPs = 10.9.0.11/32
